# ============================================================
# RIDESHARE APP — Переменные окружения
# Скопируй этот файл в .env.local и заполни своими данными
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Берёшь из: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Секретный ключ — только на сервере, НЕ начинается с NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Яндекс Карты ─────────────────────────────────────────────
# Берёшь из: https://developer.tech.yandex.ru/
NEXT_PUBLIC_YANDEX_MAPS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Приложение ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.ru
NEXT_PUBLIC_APP_NAME=РидМаркет
